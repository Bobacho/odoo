<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Plantilla de Email - Notificación SBS -->
        <record id="email_template_sbs_notification" model="mail.template">
            <field name="name">Notificación SBS - Reporte Regulatorio</field>
            <field name="model_id" ref="model_sbs_regulatory_report"/>
            <field name="email_from">${(object.company_id.email or 'notificaciones-sbs@banconacion.pe')|safe}</field>
            <field name="email_to">${object.company_id.sbs_notification_email or 'sbs-reportes@banconacion.pe'}</field>
            <field name="subject">Reporte SBS ${object.code} - ${object.date_from} a ${object.date_to}</field>
            <field name="reply_to">${(object.company_id.email or 'notificaciones-sbs@banconacion.pe')|safe}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif;">
    <h2>Reporte Regulatorio SBS</h2>
    <p><strong>Entidad:</strong> Banco de la Nación</p>
    <p><strong>Código de Reporte:</strong> ${object.code}</p>
    <p><strong>Tipo:</strong> ${dict(object._fields['report_type'].selection).get(object.report_type)}</p>
    <p><strong>Período:</strong> ${object.date_from} - ${object.date_to}</p>
    <p><strong>Estado:</strong> ${dict(object._fields['state'].selection).get(object.state)}</p>
    <p><strong>Versión:</strong> ${object.version}</p>
    <p><strong>Total Líneas:</strong> ${object.total_lines}</p>
    <p><strong>Monto Total:</strong> ${object.total_amount} ${object.currency_id.name}</p>
    <hr/>
    <p>Este reporte ha sido generado automáticamente por el sistema Odoo del Banco de la Nación.</p>
    <p>Para cualquier consulta, contactar a la Dirección de TI.</p>
    <hr/>
    <p style="color: #666; font-size: 11px;">
        Banco de la Nación - Sistema de Reportes Regulatorios SBS<br/>
        Este es un mensaje automático, por favor no responder.
    </p>
</div>
            ]]></field>
        </record>

        <!-- Plantilla de Email - Alerta Regulatoria -->
        <record id="email_template_alert_notification" model="mail.template">
            <field name="name">Alerta Regulatoria - Banco de la Nación</field>
            <field name="model_id" ref="model_alert_rule"/>
            <field name="email_from">${(object.company_id.email or 'alertas@banconacion.pe')|safe}</field>
            <field name="email_to">${','.join(object.notify_user_ids.mapped('email'))}</field>
            <field name="subject">⚠️ Alerta ${object.priority}: ${object.name}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif;">
    <h2 style="color: #d9534f;">Alerta Regulatoria</h2>
    <p><strong>Regla:</strong> ${object.name}</p>
    <p><strong>Tipo:</strong> ${dict(object._fields['alert_type'].selection).get(object.alert_type)}</p>
    <p><strong>Prioridad:</strong> ${object.priority}</p>
    <p><strong>Descripción:</strong> ${object.description}</p>
    <p><strong>Fecha:</strong> ${(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M:%S')}</p>
    <hr/>
    <p>Por favor, revise esta alerta en el sistema Odoo - Módulo Regulatorio.</p>
</div>
            ]]></field>
        </record>

        <!-- Plantilla de Email - Reporte Diario -->
        <record id="email_template_daily_report" model="mail.template">
            <field name="name">Reporte Diario de Operaciones</field>
            <field name="model_id" ref="model_sbs_regulatory_report"/>
            <field name="email_from">${(object.company_id.email or 'operaciones@banconacion.pe')|safe}</field>
            <field name="email_to">${object.company_id.sbs_notification_email or 'operaciones@banconacion.pe'}</field>
            <field name="subject">Reporte Diario - ${object.date_from}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif;">
    <h3>Reporte Diario de Operaciones</h3>
    <p><strong>Fecha:</strong> ${object.date_from}</p>
    <p><strong>Total de Operaciones:</strong> ${object.total_lines}</p>
    <p><strong>Monto Total:</strong> ${object.total_amount}</p>
    <p>Adjunto el archivo de reporte correspondiente.</p>
</div>
            ]]></field>
        </record>

    </data>
</odoo>
