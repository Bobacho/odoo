<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Grupos de seguridad bancarios -->
        <record id="group_sbs_admin" model="res.groups">
            <field name="name">SBS - Administrador Regulatorio</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Acceso total a reportes regulatorios SBS</field>
        </record>

        <record id="group_sbs_analyst" model="res.groups">
            <field name="name">SBS - Analista Regulatorio</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Generación y visualización de reportes SBS</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_sbs_auditor" model="res.groups">
            <field name="name">SBS - Auditor</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Acceso de solo lectura a reportes y auditoría</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_compliance_officer" model="res.groups">
            <field name="name">Oficial de Cumplimiento</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Gestión de alertas PLA/FT y compliance</field>
            <field name="implied_ids" eval="[(4, ref('group_sbs_analyst'))]"/>
        </record>

        <record id="group_automation_admin" model="res.groups">
            <field name="name">Administrador de Automatizaciones</field>
            <field name="category_id" ref="base.module_category_accounting"/>
            <field name="comment">Configuración de acciones automatizadas bancarias</field>
            <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
        </record>

        <!-- Categorías de usuarios bancarios -->
        <record id="bank_user_category" model="res.groups">
            <field name="name">Usuario Bancario</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <!-- Reglas de registro -->
        <record id="rule_sbs_report_company" model="ir.rule">
            <field name="name">Reportes SBS: Multi-compañía</field>
            <field name="model_id" ref="model_sbs_regulatory_report"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_automated_action_company" model="ir.rule">
            <field name="name">Acciones Automatizadas: Multi-compañía</field>
            <field name="model_id" ref="model_automated_action_log"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="rule_audit_trail_company" model="ir.rule">
            <field name="name">Auditoría: Multi-compañía</field>
            <field name="model_id" ref="model_audit_trail_entry"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
