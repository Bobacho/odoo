<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista de asistente -->
        <record id="view_sbs_report_wizard_form" model="ir.ui.view">
            <field name="name">sbs.report.wizard.form</field>
            <field name="model">sbs.report.wizard</field>
            <field name="arch" type="xml">
                <form string="Generar Reporte SBS">
                    <div class="alert alert-info" role="alert">
                        <strong>Nuevo Reporte Regulatorio SBS</strong><br/>
                        Complete los campos para generar un reporte para la Superintendencia de Banca, Seguros y AFP.
                    </div>
                    <group>
                        <group>
                            <field name="report_type"/>
                            <field name="period_type"/>
                            <field name="file_format"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <field name="generate_automatically"/>
                        <field name="notify_users"/>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Generar Reporte"
                                type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción del asistente -->
        <record id="action_sbs_report_wizard" model="ir.actions.act_window">
            <field name="name">Nuevo Reporte SBS</field>
            <field name="res_model">sbs.report.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="binding_model_id" ref="model_sbs_regulatory_report"/>
            <field name="binding_type">action</field>
        </record>

        <!-- Secuencia para códigos de reporte -->
        <record id="sequence_sbs_report_code" model="ir.sequence">
            <field name="name">Código de Reporte SBS</field>
            <field name="code">sbs.report.code</field>
            <field name="prefix">%Y%m</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
